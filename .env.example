# TranscribeOps — Environment Variables
# Kopiere diese Datei: cp .env.example .env

# Flask Secret Key (mindestens 32 Zeichen)
# Generieren: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# Whisper API Key (leer = keine Authentifizierung)
# Kann zusätzlich über das Whisper-Admin-UI verwaltet werden (mehrere Keys möglich).
WHISPER_API_KEY=

# Hugging Face Token (benötigt für Speaker Diarization)
# https://huggingface.co/settings/tokens
HF_TOKEN=

# Whisper-Admin-UI (Port 8000, Pfad /admin)
# Leer lassen = Admin-UI deaktiviert.
WHISPER_ADMIN_PASSWORD=
# Optional: Session-Secret explizit setzen; sonst wird es aus dem Passwort abgeleitet.
WHISPER_ADMIN_SESSION_SECRET=
